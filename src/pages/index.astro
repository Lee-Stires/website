---
import { Layout } from '@/layouts';
import homeData from '@/lib/data/home.json';
import { Container } from '@/components';
import R2Picture from '@/components/R2Picture.astro';
---

<Layout {...homeData.seo}>
  <Container class="mt-10">
    <R2Picture
      src={homeData.hero.image.src}
      height={750}
      width={1570}
      alt={homeData.hero.image.alt}
      class="h-auto w-full"
      loading="eager"
    />
  </Container>
</Layout>
